{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": [],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/test-setup.ts",
    "src/**/_old_implementation/**",
    "src/**/_new_implementation/**"
  ]
}
