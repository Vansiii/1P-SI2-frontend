# API Configuration
NG_APP_API_BASE_URL=http://localhost:8000/api/v1

# Firebase Cloud Messaging Configuration
# Obtener estos valores desde Firebase Console > Project Settings > General
NG_APP_FIREBASE_API_KEY=your_firebase_api_key_here
NG_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NG_APP_FIREBASE_PROJECT_ID=your-project-id
NG_APP_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NG_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NG_APP_FIREBASE_APP_ID=your_app_id
NG_APP_FIREBASE_MEASUREMENT_ID=your_measurement_id

# VAPID Key para Web Push
# Obtener desde Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
# IMPORTANTE: Debes generar este key en Firebase Console
NG_APP_FIREBASE_VAPID_KEY=your_vapid_key_here
