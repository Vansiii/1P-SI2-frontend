#!/bin/sh
# Pre-commit hook to verify subscription management

echo "Running pre-commit checks..."

# Run ESLint to check for subscription issues
npm run lint

if [ $? -ne 0 ]; then
  echo "❌ ESLint found issues. Please fix them before committing."
  echo "Run 'npm run lint:fix' to automatically fix some issues."
  exit 1
fi

echo "✅ Pre-commit checks passed!"
exit 0
